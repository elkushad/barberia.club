generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  password      String?
  role          String       @default("OWNER") // ADMIN, OWNER
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  barbershops   Barbershop[]
}

model Barbershop {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  logo        String?
  banner      String?
  description String?
  servicesLegacy String? @map("services") // legacy (JSON), sin uso; se conserva la columna
  serviceList Service[]  // servicios con precio configurables por la barbería
  hours       String?    // JSON string for simplicity in MVP
  address     String?
  whatsapp    String?
  brandColor  String?    @default("#000000")
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id])
  customers    Customer[]
  rewards      Reward[]
  appointments Appointment[]
  plan        String     @default("FREE") // FREE or PRO
  status      String     @default("ACTIVE") // ACTIVE, SUSPENDED
  expiresAt   DateTime?  // Vencimiento del PRO pagado (lo setean los webhooks de pago)
  trialEndsAt DateTime?  // Fin de la prueba gratuita PRO de 7 días (plan sigue siendo FREE)
  flyerTemplate String?  // Plantilla de flyer elegida (flyer | flyer2 | flyer3); null = default
  paypalSubscriptionId String?
  instagram   String?
  tiktok      String?
  facebook    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  payments    Payment[]
  clientReferralRewards ClientReferralReward[]
  clientReferrals       ClientReferral[]

  // --- Referidos ---
  referralCode       String?      @unique // código único de referido (ej "ABC123")
  referredById       String?               // barbería que la refirió (asociación permanente)
  referredBy         Barbershop?  @relation("Refs", fields: [referredById], references: [id])
  referidos          Barbershop[] @relation("Refs")
  discountEligible   Boolean      @default(false) // 20% del primer mes Pro disponible
  discountUsed       Boolean      @default(false) // ya consumió el descuento
  referralsMade      Referral[]   @relation("Referrer")
  referralAsReferred Referral?    @relation("Referred")
  creditMovements    CreditMovement[]
}

// Recompensa para el referente: S/5 por cada barbería referida que paga Pro.
// Se libera (AVAILABLE) recién a los 30 días si la suscripción sigue vigente.
model Referral {
  id           String     @id @default(cuid())
  referrerId   String
  referrer     Barbershop @relation("Referrer", fields: [referrerId], references: [id])
  referredId   String     @unique // 1 sola recompensa por barbería referida (antifraude)
  referred     Barbershop @relation("Referred", fields: [referredId], references: [id])
  status       String     @default("PENDING") // PENDING | AVAILABLE | CANCELLED
  rewardAmount Float      @default(5)
  proPaidAt    DateTime?  // momento del pago Pro (arranca el reloj de 30 días)
  unlockAt     DateTime?  // proPaidAt + 30 días
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Libro mayor de créditos. Saldo disponible = Σ(créditos liberados) − Σ(usados).
model CreditMovement {
  id           String     @id @default(cuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])
  amount       Float      // + = crédito liberado, − = usado en un pago
  reason       String     // REWARD_RELEASED | CREDIT_USED
  referralId   String?    // referencia opcional a la recompensa de origen
  createdAt    DateTime   @default(now())
}

// Auditoría de eventos del sistema de referidos (con timestamps).
model AuditEvent {
  id           String   @id @default(cuid())
  barbershopId String?  // barbería afectada (si aplica)
  type         String   // REFERRAL_CREATED, REFERRAL_SIGNUP, REFERRAL_PRO_PAYMENT, ...
  meta         String?  // JSON con detalle del evento
  createdAt    DateTime @default(now())
}

model Customer {
  id           String       @id @default(cuid())
  name         String
  phone        String
  status       String       @default("PENDING") // PENDING, ACTIVE
  uniqueCode   String?      @unique
  barbershopId String
  barbershop   Barbershop   @relation(fields: [barbershopId], references: [id])
  visits       Visit[]
  redemptions  Redemption[]
  appointments Appointment[]
  referralsMade    ClientReferral[] @relation("ClientReferrer")
  referralReceived ClientReferral?  @relation("ClientReferred")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([phone, barbershopId]) // Phone must be unique per barbershop
}

model Appointment {
  id           String     @id @default(cuid())
  date         String     // Fecha elegida por el cliente (YYYY-MM-DD)
  time         String     // Hora elegida (HH:mm)
  status       String     @default("PENDING") // PENDING, APPROVED, COMPLETED, CANCELLED
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id])
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Visit {
  id           String     @id @default(cuid())
  status       String     @default("PENDING") // PENDING, CONFIRMED, REJECTED
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id])
  serviceId    String?
  service      Service?   @relation(fields: [serviceId], references: [id])
  servicePrice Float?     // precio del servicio al momento de la visita (snapshot)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Service {
  id           String     @id @default(cuid())
  name         String
  price        Float      @default(0)
  isPrimary    Boolean    @default(false) // servicio principal (default al registrar visitas)
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])
  visits       Visit[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Reward {
  id             String       @id @default(cuid())
  name           String
  image          String?
  visitsRequired Int
  barbershopId   String
  barbershop     Barbershop   @relation(fields: [barbershopId], references: [id])
  redemptions    Redemption[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Redemption {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  rewardId   String
  reward     Reward   @relation(fields: [rewardId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Payment {
  id           String     @id @default(cuid())
  amount       Float
  currency     String     @default("PEN")
  status       String     @default("PAID") // PAID, PENDING, FAILED
  method       String     @default("CREDIT_CARD")
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Recompensa por referidos que configura cada barbería para sus clientes.
// "Invita X amigos → gana Y"
model ClientReferralReward {
  id                String           @id @default(cuid())
  barbershopId      String
  barbershop        Barbershop       @relation(fields: [barbershopId], references: [id])
  name              String           // "Corte gratis por referidos"
  rewardType        String           @default("TEXT") // CORTE_GRATIS | DESCUENTO | PRODUCTO | TEXT
  description       String?
  referralsRequired Int              @default(2)
  isActive          Boolean          @default(true)
  isPrimary         Boolean          @default(false) // Solo 1 puede ser principal (destacada al cliente)
  referrals         ClientReferral[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

// Registro de quién invitó a quién dentro de una barbería.
// Un cliente solo puede ser referido una vez por barbería (unique referredId).
model ClientReferral {
  id           String                @id @default(cuid())
  barbershopId String
  barbershop   Barbershop            @relation(fields: [barbershopId], references: [id])
  rewardId     String?
  reward       ClientReferralReward? @relation(fields: [rewardId], references: [id])
  referrerId   String
  referrer     Customer              @relation("ClientReferrer", fields: [referrerId], references: [id])
  referredId   String                @unique
  referred     Customer              @relation("ClientReferred", fields: [referredId], references: [id])
  // REGISTRADO → VISITA_APROBADA
  status       String                @default("REGISTRADO")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}
