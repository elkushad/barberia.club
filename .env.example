# Copia este archivo a `.env` y completa los valores.
# NUNCA subas tu archivo .env real al repositorio.

# --- Base de datos (Prisma · PostgreSQL) ---
# Usa Postgres en todos los entornos (Neon, Supabase, etc.).
DATABASE_URL="postgresql://usuario:password@host:5432/barberia?sslmode=require"

# --- NextAuth ---
# Secreto para firmar los JWT de sesión. Obligatorio en producción.
# Genéralo con:  openssl rand -base64 32
NEXTAUTH_SECRET=""
# URL pública de la app (requerida por NextAuth en producción).
NEXTAUTH_URL="http://localhost:3000"

# --- App ---
# URL pública usada para construir el enlace del QR y las metaetiquetas (SEO/OG).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ID de medición de Google Analytics 4 (forma G-XXXXXXXXXX). Opcional:
# sobreescribe el ID por defecto del proyecto (configurado en src/app/layout.tsx).
NEXT_PUBLIC_GA_ID=""

# ID del Píxel de Meta (número). Opcional: sobreescribe el ID por defecto del proyecto.
NEXT_PUBLIC_META_PIXEL_ID=""

# ID del Píxel de TikTok. Opcional: sobreescribe el ID por defecto del proyecto.
NEXT_PUBLIC_TIKTOK_PIXEL_ID=""

# --- PayPal (suscripciones) ---
# Por defecto apunta a Sandbox. Para producción usa credenciales Live y
# PAYPAL_API_BASE="https://api-m.paypal.com".
PAYPAL_CLIENT_SECRET=""
PAYPAL_API_BASE="https://api-m.sandbox.paypal.com"
# ID del webhook de PayPal (con valor por defecto de Sandbox en el código).
PAYPAL_WEBHOOK_ID=""

# --- Mercado Pago ---
MERCADOPAGO_ACCESS_TOKEN=""

# --- Tipo de cambio (exchangerate-api.com) ---
# Para mostrar el precio aproximado en la moneda local en /planes.
EXCHANGE_RATE_API_KEY=""
# Públicos (con valor por defecto de Sandbox en el código; sobreescribir para Live):
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
NEXT_PUBLIC_PAYPAL_PLAN_ID=""

# --- Almacenamiento de imágenes (Vercel Blob) ---
# Token de lectura/escritura (Vercel → Project → Storage → Blob).
BLOB_READ_WRITE_TOKEN=""

# --- Seed inicial (scripts/seed.mjs) ---
# Credenciales de las cuentas de prueba. Cámbialas; no uses estos valores en producción.
SEED_ADMIN_EMAIL="admin@barberia.club"
SEED_ADMIN_PASSWORD=""
SEED_OWNER_EMAIL="owner@demo.com"
SEED_OWNER_PASSWORD=""
